# Enable Git LFS before committing large exported media or generated indexes:
#   git lfs install
#   git lfs track
#
# These patterns cover common Discord attachments and derived binary/vector shards.
data/attachments/** filter=lfs diff=lfs merge=lfs -text
data/media/** filter=lfs diff=lfs merge=lfs -text
data/attachments/.gitkeep -filter -diff -merge text
data/media/.gitkeep -filter -diff -merge text
data/index/**/*.bin filter=lfs diff=lfs merge=lfs -text
data/index/**/*.parquet filter=lfs diff=lfs merge=lfs -text
data/index/**/*.sqlite filter=lfs diff=lfs merge=lfs -text
data/index/**/*.sqlite3 filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text
